# Copy to .env and fill in. The .env file is gitignored.

# TensorZero gateway needs at least one of these to actually run inferences.
# For the demo, OPENAI_API_KEY or ANTHROPIC_API_KEY is enough.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Operator signing key for Vismaran receipts. If unset, the orchestrator
# refuses to sign and raises ConfigurationError. Generate with:
#   vismaran keygen > keys/operator.key  (Day 5+)
VISMARAN_SIGNING_KEY_PATH=./keys/operator.key

# Salt used to hash subject IDs in receipts. Per-deployment, MUST be persistent
# (otherwise old receipts become unverifiable).
VISMARAN_SUBJECT_SALT=replace-me-with-a-32-byte-random-value

# Operator identifier, embedded in every receipt.
VISMARAN_OPERATOR_ID=your-company-vismaran-deploy-01
